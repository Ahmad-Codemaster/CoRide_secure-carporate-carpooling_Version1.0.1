<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_low"
    android:orientation="vertical">

    <!-- M3 Small Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        style="@style/Widget.InDrive.AppBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.InDrive.TopAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/on_surface"
            app:title="@string/driver_offers"
            app:titleTextColor="@color/on_surface" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

<!--            &lt;!&ndash; Nearby Drivers Map Widget &ndash;&gt;-->
<!--            <com.google.android.material.card.MaterialCardView-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="280dp"-->
<!--                android:layout_margin="@dimen/spacing_md"-->
<!--                app:cardCornerRadius="@dimen/shape_large"-->
<!--                app:cardElevation="@dimen/elevation_sm"-->
<!--                app:strokeColor="@color/outline_variant"-->
<!--                app:strokeWidth="1dp">-->

<!--                <androidx.fragment.app.FragmentContainerView-->
<!--                    android:id="@+id/offersMapView"-->
<!--                    android:name="com.google.android.gms.maps.SupportMapFragment"-->
<!--                    android:layout_width="match_parent"-->
<!--                    android:layout_height="match_parent"-->
<!--                    tools:layout="@layout/view_map_placeholder" />-->
<!--            </com.google.android.material.card.MaterialCardView>-->

            <!-- Ride Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_md"
                android:layout_marginTop="40dp"
                app:cardCornerRadius="@dimen/shape_medium"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvOfferDestination"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Destination"
                            android:textAppearance="@style/TextAppearance.InDrive.TitleMedium"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Your request"
                            android:textAppearance="@style/TextAppearance.InDrive.BodySmall"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvYourFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:text="Rs. 0"
                        android:textAppearance="@style/TextAppearance.InDrive.HeadlineSmall"
                        android:textColor="@color/primary" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Searching State / Offers List -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/searchingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/primary_container"
                        app:trackThickness="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/searching_drivers"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body_medium" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOffers"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:clipToPadding="false"
                    android:paddingVertical="@dimen/spacing_sm" />
            </FrameLayout>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_margin="@dimen/spacing_md"
                android:text="@string/cancel"
                style="@style/Widget.InDrive.Button.Secondary" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
