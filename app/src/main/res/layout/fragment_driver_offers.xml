<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_low"
    android:orientation="vertical">

    <!-- M3 Small Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        style="@style/Widget.InDrive.AppBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/Widget.InDrive.TopAppBar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/on_surface"
            app:title="@string/driver_offers"
            app:titleTextColor="@color/on_surface" />
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Nearby Drivers Map Widget -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_margin="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/shape_large"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp">

                <fragment
                    android:id="@+id/offersMapView"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Ride Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/shape_large"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface_container_lowest">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_circle_primary" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:text="Your Location"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_body_small" />

                        <TextView
                            android:id="@+id/tvYourFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_title_medium"
                            android:fontFamily="sans-serif-bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="2dp"
                        android:layout_height="10dp"
                        android:layout_marginStart="3dp"
                        android:background="@color/outline_variant" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_circle_secondary" />

                        <TextView
                            android:id="@+id/tvOfferDestination"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_body_small" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Searching State / Offers List -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/searchingContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminate="true"
                        app:indicatorColor="@color/primary"
                        app:trackColor="@color/primary_container"
                        app:trackThickness="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="@string/searching_drivers"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body_medium" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOffers"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone"
                    android:clipToPadding="false"
                    android:paddingVertical="@dimen/spacing_sm" />
            </FrameLayout>

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_margin="@dimen/spacing_md"
                android:text="@string/cancel"
                style="@style/Widget.InDrive.Button.Secondary" />
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
