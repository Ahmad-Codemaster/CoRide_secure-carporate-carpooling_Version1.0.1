<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <!-- Map Full Background -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/homeMapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout="@layout/view_map_placeholder" />

    <!-- Center Pin (Hidden by default, enabled in manual mode) -->
    <ImageView
        android:id="@+id/ivCenterPin"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginBottom="20dp"
        android:src="@drawable/ic_location_pin"
        android:visibility="gone"
        app:tint="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Material 3 Search Bar (The Floating Entry Point) -->
    <com.google.android.material.search.SearchBar
        android:id="@+id/mapSearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_md"
        android:hint="Search any place or restaurant..."
        app:navigationIcon="@drawable/ic_arrow_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Material 3 Search View (The Active Search Full-Screen Overlay) -->
    <com.google.android.material.search.SearchView
        android:id="@+id/mapSearchView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:hint="Search any place or restaurant..."
        app:layout_anchor="@id/mapSearchBar">

        <!-- Suggestion List -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:id="@+id/btnPickOnMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                app:layout_constraintTop_toTopOf="parent">
                
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/location"
                    app:tint="?attr/colorPrimary"/>
                    
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Set location on map"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchSuggestions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@id/btnPickOnMap"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.search.SearchView>

    <!-- My Location FAB + Loading Spinner Container -->
    <FrameLayout
        android:id="@+id/fabMyLocationContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginBottom="@dimen/spacing_md"
        app:layout_constraintBottom_toTopOf="@id/btnSaveLocation"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabMyLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/location"
            app:tint="?attr/colorPrimary"
            app:backgroundTint="?attr/colorSurface"
            app:fabSize="normal"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full" />

        <ProgressBar
            android:id="@+id/locationProgressBar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:padding="8dp"
            android:indeterminate="true"
            android:visibility="gone"
            android:elevation="6dp" />
    </FrameLayout>

    <!-- Save Location Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveLocation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginHorizontal="@dimen/spacing_lg"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:text="Save Location"
        style="@style/Widget.CoRide.Button.Primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 5. Weather Action Corner (Bottom Right, Stacked Above Location FAB) -->
    <LinearLayout
        android:id="@+id/mapWeatherContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="@dimen/spacing_md"
        android:gravity="end"
        app:layout_constraintBottom_toTopOf="@id/fabMyLocationContainer"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Weather Popup Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWeatherPopupMap"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/shape_large"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface">

            <LinearLayout
                android:id="@+id/layoutWeatherDaysMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_sm" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Static Blue Outline + FAB Container -->
        <FrameLayout
            android:layout_width="58dp"
            android:layout_height="64dp">

            <ImageView
                android:id="@+id/ivWeatherGlowMap"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_weather_glow_aurora" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_sunny"
                app:tint="?attr/colorPrimary"
                app:backgroundTint="?attr/colorSurface"
                app:fabSize="mini"
                app:elevation="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


