<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- FULL SCREEN MAP -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/rideMapView"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:layout="@layout/view_map_placeholder" />

    <!-- MODERN TOP HUD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusChipContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#A60F172A"
        app:strokeWidth="1dp"
        app:strokeColor="#33FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="0"
        android:translationY="-60dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_secondary"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvRideStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Driver Arriving"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvEtaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="• ETA: 5 min"
                android:textColor="#CBD5E1"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Deviation Warning Alert -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvDeviationWarning"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:cardBackgroundColor="#EF4444"
        app:cardCornerRadius="16dp"
        app:cardElevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/statusChipContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_warning"
                app:tint="#FFFFFF" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Route deviation detected! Check safety."
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- THE UNIFIED SAFETY PILL HUD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSafetyPill"
        android:layout_width="60dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="100dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#A6FFFFFF"
        app:strokeWidth="1dp"
        app:strokeColor="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingVertical="12dp">

            <!-- SOS -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_warning"
                app:tint="#F44336"
                app:backgroundTint="#30EF4444"
                app:fabSize="mini"
                app:elevation="0dp"
                app:borderWidth="0dp" />

            <!-- Share -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabShare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_share"
                app:tint="#0F172A"
                app:backgroundTint="#2C3F3F40"
                app:fabSize="mini"
                app:elevation="0dp"
                app:borderWidth="0dp" />

            <!-- SOS Info -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabSosInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_info"
                app:tint="#4CAF50"
                app:backgroundTint="#234CAF50"
                app:fabSize="mini"
                app:elevation="0dp"
                app:borderWidth="0dp" />

            <!-- COLORFUL WEATHER -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_sunny"
                app:tint="#EAB308"
                app:backgroundTint="#1DFFC107"
                app:fabSize="mini"
                app:elevation="0dp"
                app:borderWidth="0dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Weather Popup — NOW ON THE LEFT -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvWeatherPopupRide"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintEnd_toStartOf="@id/cvSafetyPill"
        app:layout_constraintBottom_toBottomOf="@id/cvSafetyPill"
        android:layout_marginBottom="10dp">
        <LinearLayout
            android:id="@+id/layoutWeatherDaysRide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- SOS Info Popup — ALSO ON THE LEFT -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSosInfoPopup"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintEnd_toStartOf="@id/cvSafetyPill"
        app:layout_constraintTop_toTopOf="@id/cvSafetyPill"
        android:layout_marginTop="20dp">
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Press Volume Down 3 times to trigger instant SOS help."
            android:textColor="#475569"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium" />
    </com.google.android.material.card.MaterialCardView>

    <!-- PREMIUM DRIVER AND RIDE STATUS PANEL -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/rideBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:backgroundTint="#FFFFFF"
        android:elevation="20dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <!-- Drag Handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center"
                android:layout_marginBottom="20dp"
                android:background="#E2E8F0" />

            <!-- PREMIUM DRIVER IDENTITY CARD -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_outlined"
                android:padding="16dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivDriverProfile"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/profile"
                    android:padding="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <LinearLayout
                    android:id="@+id/layoutDriverInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintStart_toEndOf="@id/ivDriverProfile"
                    app:layout_constraintEnd_toStartOf="@id/layoutDriverActions"
                    app:layout_constraintTop_toTopOf="@id/ivDriverProfile"
                    app:layout_constraintBottom_toBottomOf="@id/ivDriverProfile">

                    <TextView
                        android:id="@+id/tvDriverName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bilal Ahmed"
                        android:textColor="#0F172A"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-bold" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5.0"
                            android:textColor="#EAB308"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold" />
                        <TextView
                            android:id="@+id/tvDriverRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="(4.6)"
                            android:textColor="#64748B"
                            android:textSize="12sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="• Verified"
                            android:textColor="#10B981"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutDriverActions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCall"
                        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="8dp"
                        app:icon="@drawable/ic_call"
                        app:iconTint="?attr/colorPrimary"
                        app:backgroundTint="#F1F5F9" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnMessage"
                        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_email"
                        app:iconTint="?attr/colorPrimary"
                        app:backgroundTint="#F1F5F9" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- VEHICLE BADGE ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F8FAFC"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0">
                    <TextView
                        android:id="@+id/tvVehicleInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="Yellow Sazgar 7-Seater"
                        android:textColor="#475569"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />
                </com.google.android.material.card.MaterialCardView>

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0F172A">
                    <TextView
                        android:id="@+id/tvPlateNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="6dp"
                        android:text="LED-3456"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- ROUTE TIMELINE VIEW -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">

                <View
                    android:id="@+id/dotPickup"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_circle_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    android:layout_marginTop="6dp" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="32dp"
                    android:background="#E2E8F0"
                    app:layout_constraintStart_toStartOf="@id/dotPickup"
                    app:layout_constraintEnd_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toBottomOf="@id/dotPickup" />

                <View
                    android:id="@+id/dotDest"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_circle_secondary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dotPickup"
                    android:layout_marginTop="36dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Today's Ride"
                    android:textColor="#94A3B8"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:textAllCaps="true"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvPickupName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Current Location"
                    android:textColor="#475569"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toEndOf="@id/dotPickup"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvDestination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Karachi"
                    android:textColor="#1E293B"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-bold"
                    app:layout_constraintStart_toEndOf="@id/dotDest"
                    app:layout_constraintTop_toTopOf="@id/dotDest"
                    app:layout_constraintEnd_toStartOf="@id/tvFare"
                    app:layout_constraintBottom_toBottomOf="@id/dotDest" />

                <TextView
                    android:id="@+id/tvFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₨ 38,880"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tvDestination"
                    app:layout_constraintBottom_toBottomOf="@id/tvDestination" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- CANCEL BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelRide"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Cancel Ride"
                android:textAllCaps="false"
                android:letterSpacing="0"
                app:cornerRadius="28dp"
                android:backgroundTint="#0F172A"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
