<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <!-- Map Widget Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/rideMapCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/shape_large"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusChipContainer">

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/rideMapView"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:layout="@layout/view_map_placeholder" />
    </androidx.cardview.widget.CardView>

    <!-- M3 Status Chip -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusChipContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/shape_full"
        app:cardElevation="@dimen/elevation_md"
        app:cardBackgroundColor="?attr/colorPrimary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="0"
        android:translationY="-60dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvRideStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/driver_arriving"
                android:textColor="?attr/colorOnPrimary"
                android:textSize="@dimen/text_label_large"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvEtaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textColor="?attr/colorOnPrimary"
                android:alpha="0.8"
                android:textSize="@dimen/text_body_small" />

            <TextView
                android:id="@+id/tvDistanceAway"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="0.0 km"
                android:textColor="?attr/colorOnPrimary"
                android:alpha="0.7"
                android:textSize="@dimen/text_label_small"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Safety FABs -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_md"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Share -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:src="@drawable/ic_share"
            android:contentDescription="Share Ride"
            app:tint="?attr/colorPrimary"
            app:backgroundTint="?attr/colorSurface"
            app:fabSize="mini"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full"
            app:elevation="@dimen/elevation_md"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5" />

        <!-- SOS -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:src="@drawable/ic_warning"
            android:contentDescription="SOS"
            app:tint="?attr/colorOnError"
            app:backgroundTint="?attr/colorError"
            app:fabSize="mini"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full"
            app:elevation="@dimen/elevation_md"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5" />

        <!-- Instant SOS Info -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSosInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_info"
            android:contentDescription="Instant SOS Help"
            app:tint="?attr/colorPrimary"
            app:backgroundTint="?attr/colorSurface"
            app:fabSize="mini"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full"
            app:elevation="@dimen/elevation_md"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5" />
    </LinearLayout>

    <!-- Instant SOS Guidance Popup -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSosInfoPopup"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/spacing_md"
        android:visibility="gone"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeWidth="1dp"
        app:strokeColor="#e2e8f0"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintEnd_toStartOf="@+id/weatherActionCornerRide"
        android:layout_marginTop="60dp"
        tools:ignore="MissingConstraints,UnknownId">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Instant SOS:"
                android:textColor="?attr/colorPrimary"
                android:textSize="@dimen/text_label_large"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Press 3 times vol down button to trigger instant sos"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_body_small" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- M3 Driver Panel Bottom Sheet -->
    <LinearLayout
        android:id="@+id/rideBottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:backgroundTint="#FFFFFF"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_lg"
        android:paddingHorizontal="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- M3 Drag Handle -->
        <View
            android:layout_width="@dimen/drag_handle_width"
            android:layout_height="@dimen/drag_handle_height"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/indicator_m3_drag" />

        <!-- Driver Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivDriverProfile"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/profile"
                android:scaleType="centerCrop"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDriverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_title_medium"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5★"
                        android:textColor="@color/star_yellow"
                        android:textSize="@dimen/text_title_small" />

                    <TextView
                        android:id="@+id/tvDriverRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="@dimen/text_body_small" />
                </LinearLayout>
            </LinearLayout>

            <!-- Action Buttons -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCallContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/shape_full"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <ImageView
                    android:id="@+id/btnCall"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_call"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorPrimary" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnMessageContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="@dimen/shape_full"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="?attr/colorOutlineVariant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <ImageView
                    android:id="@+id/btnMessage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_email"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="?attr/colorPrimary" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_md"
            android:background="?attr/colorOutlineVariant" />

        <!-- Vehicle Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVehicleInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_small" />

            <!-- Plate Number -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/shape_small"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <TextView
                    android:id="@+id/tvPlateNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_secondary" />

            <TextView
                android:id="@+id/tvDestination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_small" />
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/shape_small"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <TextView
                    android:id="@+id/tvFare"
                    android:layout_width="70dp"
                    android:layout_height="25dp"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="@dimen/text_title_medium"
                    android:fontFamily="sans-serif-bold" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelRide"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/cancel_ride"
            android:textColor="@color/accent_light" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/weatherActionCornerRide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="280dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:gravity="end"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Weather Popup -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWeatherPopupRide"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:id="@+id/layoutWeatherDaysRide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/ivWeatherGlowRide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_weather_glow_aurora" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_sunny"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="0dp"
                app:fabSize="mini"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full"
                app:tint="?attr/colorPrimary"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
        </FrameLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


