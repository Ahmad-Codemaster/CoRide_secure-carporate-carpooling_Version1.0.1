<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Map Widget Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/rideMapCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/shape_large"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/statusChipContainer">

        <fragment
            android:id="@+id/rideMapView"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </androidx.cardview.widget.CardView>

    <!-- M3 Status Chip — spring entrance from top -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/statusChipContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_md"
        app:cardCornerRadius="@dimen/shape_full"
        app:cardElevation="@dimen/elevation_md"
        app:cardBackgroundColor="@color/primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:alpha="0"
        android:translationY="-60dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingVertical="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvRideStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/driver_arriving"
                android:textColor="@color/on_primary"
                android:textSize="@dimen/text_label_large"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvEtaStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textColor="#A0E8FF"
                android:textSize="@dimen/text_body_small" />

            <TextView
                android:id="@+id/tvDistanceAway"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="0.0 km"
                android:textColor="#CCFFFFFF"
                android:textSize="@dimen/text_label_small"
                android:fontFamily="sans-serif-medium"
                tools:ignore="HardcodedText" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Safety FABs — top right, spring pop entrance -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/spacing_md"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Share -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabShare"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:src="@drawable/ic_share"
            android:contentDescription="Share Ride"
            app:tint="@color/primary"
            app:backgroundTint="@color/surface_container_lowest"
            app:fabSize="mini"
            app:shapeAppearance="@style/ShapeAppearance.InDrive.Full"
            app:elevation="@dimen/elevation_md"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5" />

        <!-- SOS -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/ic_warning"
            android:contentDescription="SOS"
            app:tint="@color/on_error"
            app:backgroundTint="@color/error"
            app:fabSize="mini"
            app:shapeAppearance="@style/ShapeAppearance.InDrive.Full"
            app:elevation="@dimen/elevation_md"
            android:alpha="0"
            android:scaleX="0.5"
            android:scaleY="0.5" />
    </LinearLayout>

    <!-- M3 Driver Panel Bottom Sheet -->
    <LinearLayout
        android:id="@+id/rideBottomSheet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_lg"
        android:paddingHorizontal="@dimen/spacing_lg"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- M3 Drag Handle -->
        <View
            android:layout_width="@dimen/drag_handle_width"
            android:layout_height="@dimen/drag_handle_height"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/spacing_md"
            android:background="@drawable/indicator_m3_drag" />

        <!-- Driver Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- ShapeableImageView avatar -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivDriverAvatar"
                android:layout_width="@dimen/avatar_md"
                android:layout_height="@dimen/avatar_md"
                android:src="@drawable/ic_location_pin"
                android:scaleType="centerCrop"
                android:tint="@color/on_surface_variant"
                android:padding="@dimen/spacing_md"
                android:background="@color/surface_container"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.InDrive.Full"
                android:contentDescription="Driver" />

            <!-- Name + Rating -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_md"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDriverName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_title_medium"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textColor="@color/tertiary_container"
                        android:textSize="@dimen/text_title_small" />

                    <TextView
                        android:id="@+id/tvDriverRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body_small" />
                </LinearLayout>
            </LinearLayout>

            <!-- Call Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnCallContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/shape_full"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface_container_low">

                <ImageView
                    android:id="@+id/btnCall"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_call"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Call"
                    app:tint="@color/primary" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Message Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnMessageContainer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                app:cardCornerRadius="@dimen/shape_full"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface_container_low">

                <ImageView
                    android:id="@+id/btnMessage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_email"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Message"
                    app:tint="@color/primary" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Thin divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="@dimen/spacing_md"
            android:background="@color/outline_variant" />

        <!-- Vehicle Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvVehicleInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body_small" />

            <!-- Plate Number — M3 AssistChip style -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/shape_small"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="@color/outline"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface_container">

                <TextView
                    android:id="@+id/tvPlateNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:paddingVertical="@dimen/spacing_xs"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-bold" />
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Destination + Fare Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_md"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_circle_secondary" />

            <TextView
                android:id="@+id/tvDestination"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body_small" />

            <TextView
                android:id="@+id/tvFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Cancel — Text button with error color -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelRide"
            style="@style/Widget.InDrive.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="@dimen/spacing_md"
            android:text="@string/cancel_ride"
            android:textColor="@color/error"
            tools:ignore="VisualLintButtonSize" />

    </LinearLayout>

    <!-- 5. Weather Action Corner (Bottom Right, Above Driver Panel) -->
    <LinearLayout
        android:id="@+id/weatherActionCornerRide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="280dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:gravity="end"
        android:translationZ="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Weather Popup Card (Solid White, Above FAB) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWeatherPopupRide"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:alpha="0"
            android:translationY="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"> <!-- Solid White -->
            <LinearLayout
                android:id="@+id/layoutWeatherDaysRide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Spiral Outline + FAB Container -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp">

            <!-- Animated Spiral Ring -->
            <ProgressBar
                android:id="@+id/pbWeatherSpiralRide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:indeterminate="true"
                android:indeterminateDrawable="@drawable/ic_playstore_spinner" />

            <!-- Shadowless Weather FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_sunny"
                app:tint="@color/primary"
                app:backgroundTint="@color/surface_container_lowest"
                app:fabSize="mini"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.InDrive.Full" />
        </FrameLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
