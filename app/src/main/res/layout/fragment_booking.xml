<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface">

    <!-- Map & Floating Elements Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Map — Full Screen Background -->
        <fragment
            android:id="@+id/bookingMapView"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Center Pin Selector — only visible in pick mode -->
        <ImageView
            android:id="@+id/ivCenterPin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_location_pin"
            android:visibility="gone"
            app:tint="@color/primary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="20dp" />

        <!-- Picking Header — only visible in pick mode -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pickingHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/shape_full"
            app:cardElevation="@dimen/elevation_md"
            app:cardBackgroundColor="@color/surface_container_highest"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <TextView
                android:id="@+id/tvPickingTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="Set your location"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_body_large"
                android:fontFamily="sans-serif-medium" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Back button — M3 surface container circle -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnBackContainer"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_margin="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/shape_full"
            app:cardElevation="@dimen/elevation_md"
            app:cardBackgroundColor="@color/surface_container_lowest"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                app:tint="@color/on_surface" />
        </com.google.android.material.card.MaterialCardView>

        <!-- My Location Button + Pulse Spinner -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_md"
            android:layout_marginBottom="160dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.5">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_my_location"
                android:contentDescription="My Location"
                app:tint="@color/primary"
                app:backgroundTint="@color/surface_container_lowest"
                app:fabSize="mini"
                app:shapeAppearance="@style/ShapeAppearance.InDrive.Full" />

            <ProgressBar
                android:id="@+id/locationProgressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:padding="4dp"
                android:indeterminate="true"
                android:visibility="gone"
                android:elevation="6dp" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="Confirm Location"
            android:visibility="gone"
            style="@style/Widget.InDrive.Button.Primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Restore Booking Sheet Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBringUpSheet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="Continue Booking"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.ElevatedButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Draggable Bottom Sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bookingSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:behavior_hideable="false"
        app:behavior_peekHeight="120dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_xl"
            android:paddingHorizontal="@dimen/spacing_lg">

            <!-- M3 Drag Handle -->
            <View
                android:layout_width="@dimen/drag_handle_width"
                android:layout_height="@dimen/drag_handle_height"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:background="@drawable/indicator_m3_drag" />

            <!-- Route Info Widget -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/surface_container_low"
                android:padding="@dimen/spacing_md">

                <!-- Pickup Row -->
                <LinearLayout
                    android:id="@+id/rowPickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_circle_primary" />

                    <TextView
                        android:id="@+id/tvPickupLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Your Location"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Connector line -->
                <View
                    android:layout_width="2dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:background="@color/outline_variant" />

                <!-- Destination Row -->
                <LinearLayout
                    android:id="@+id/rowDestination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_circle_secondary" />

                    <TextView
                        android:id="@+id/tvDestinationLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Tap to set destination"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="@color/outline_variant" />

            <!-- Ride Type Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_ride"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-medium" />

            <!-- M3 FilterChip Row for Ride Types -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:scrollbars="none">

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/rideTypeChipGroup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipEconomy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/economy"
                        android:checked="true"
                        style="@style/Widget.Material3.Chip.Filter"
                        app:chipIcon="@drawable/ic_car" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipComfort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/comfort"
                        style="@style/Widget.Material3.Chip.Filter"
                        app:chipIcon="@drawable/ic_car" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipXL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/xl"
                        style="@style/Widget.Material3.Chip.Filter"
                        app:chipIcon="@drawable/ic_car" />
                </com.google.android.material.chip.ChipGroup>
            </HorizontalScrollView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="@color/outline_variant" />

            <!-- Offer Fare Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/offer_your_fare"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvRecommendedFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body_small" />

            <!-- M3 Fare Stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMinusContainer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="@dimen/shape_full"
                    app:cardElevation="@dimen/elevation_none"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="@color/surface_container">

                    <ImageView
                        android:id="@+id/btnMinus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_delete"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Decrease" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Fare Display -->
                <EditText
                    android:id="@+id/etFare"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:background="@color/surface_container"
                    android:gravity="center"
                    android:inputType="number"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_headline_small"
                    android:fontFamily="sans-serif-bold"
                    android:importantForAutofill="no" />

                <!-- Plus icon button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPlusContainer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="@dimen/shape_full"
                    app:cardElevation="@dimen/elevation_none"
                    app:strokeColor="@color/outline_variant"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/primary_container">

                    <ImageView
                        android:id="@+id/btnPlus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_add"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Increase" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Comment Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="Add comment for driver...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:importantForAutofill="no" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Find Driver Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindDriver"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/find_driver"
                style="@style/Widget.InDrive.Button.Primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
