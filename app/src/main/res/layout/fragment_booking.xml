<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F5F9">

    <!-- Map & Floating Elements Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Map — Full Screen Background -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/bookingMapView"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:layout="@layout/view_map_placeholder" />

        <!-- NEW DETACHED SMART SEARCH BAR -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutBookingToolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp"
            android:background="#00000000"
            android:translationZ="10dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#0f172a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSearchContainer"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                app:strokeWidth="1dp"
                app:strokeColor="#f1f5f9"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">

                    <ImageView
                        android:id="@+id/ivSearchIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        app:tint="#94a3b8"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />

                    <EditText
                        android:id="@+id/etBookingSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:background="@null"
                        android:hint="Search destination..."
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:textColor="#1e293b"
                        android:textColorHint="#94a3b8"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintStart_toEndOf="@id/ivSearchIcon"
                        app:layout_constraintEnd_toStartOf="@id/btnClearSearchText" />

                    <ImageView
                        android:id="@+id/btnClearSearchText"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:padding="10dp"
                        android:src="@drawable/ic_clear"
                        app:tint="#cbd5e1"
                        android:visibility="gone"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Integrated Search Results Below Bar -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvIntegratedSearch"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:paddingTop="12dp"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            android:visibility="gone"
            android:background="@android:color/transparent"
            android:translationZ="9dp"
            app:layout_constraintTop_toBottomOf="@id/layoutBookingToolbar"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Center Pin Selector — only visible in manual mode -->
        <ImageView
            android:id="@+id/ivCenterPin"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_location_pin"
            android:visibility="gone"
            app:tint="?attr/colorPrimary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="20dp" />

        <!-- Picking Header — only visible in manual mode -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pickingHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="80dp"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/shape_full"
            app:cardElevation="@dimen/elevation_md"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">
            
            <TextView
                android:id="@+id/tvPickingTask"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingVertical="@dimen/spacing_sm"
                android:text="Drop pin to select"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_body_large"
                android:fontFamily="sans-serif-medium" />
        </com.google.android.material.card.MaterialCardView>

        <!-- My Location Button + Pulse Spinner -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_md"
            android:layout_marginBottom="160dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.5">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/location"
                android:contentDescription="My Location"
                app:tint="#2196F3"
                app:backgroundTint="?attr/colorSurface"
                app:fabSize="mini"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full" />

            <ProgressBar
                android:id="@+id/locationProgressBar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:padding="4dp"
                android:indeterminate="true"
                android:visibility="gone"
                android:elevation="6dp" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="Confirm Location"
            android:visibility="gone"
            style="@style/Widget.CoRide.Button.Primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Restore Booking Sheet Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBringUpSheet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:text="Continue Booking"
            android:visibility="gone"
            style="@style/Widget.Material3.Button.ElevatedButton"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Draggable Bottom Sheet -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bookingSheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:behavior_hideable="false"
        app:behavior_peekHeight="120dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        android:background="@drawable/bg_bottom_sheet"
        android:elevation="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_xl"
            android:paddingHorizontal="@dimen/spacing_lg">

            <!-- M3 Drag Handle -->
            <View
                android:layout_width="@dimen/drag_handle_width"
                android:layout_height="@dimen/drag_handle_height"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:backgroundTint="@color/primary"
                android:background="@drawable/indicator_m3_drag" />

            <!-- Route Info Widget -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="@dimen/spacing_md">

                <!-- Pickup Row -->
                <LinearLayout
                    android:id="@+id/rowPickup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_circle_primary" />

                    <TextView
                        android:id="@+id/tvPickupLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Your Location"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_body_medium"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Connector line -->
                <View
                    android:layout_width="2dp"
                    android:layout_height="14dp"
                    android:layout_marginStart="4dp"
                    android:background="?attr/colorOutlineVariant" />

                <!-- Destination Row -->
                <LinearLayout
                    android:id="@+id/rowDestination"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_circle_secondary" />

                    <TextView
                        android:id="@+id/tvDestinationLocation"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Tap to set destination"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="@dimen/text_body_medium"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="?attr/colorOutlineVariant" />

            <!-- Ride Type Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/choose_ride"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-medium" />

            <!-- Professional Vehicle Selection Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:weightSum="3">

                <!-- Bike Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardBike"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardCornerRadius="16dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CBD5E1"
                    app:cardBackgroundColor="#FFE4E6"> <!-- Pastel Pink -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            android:src="@drawable/bike"
                            android:scaleType="centerInside" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bike"
                            android:textColor="#0f172a"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Rickshaw Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardRickshaw"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="2dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CBD5E1"
                    app:cardBackgroundColor="#DCFCE7"> <!-- Pastel Green -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            android:src="@drawable/rikshaw"
                            android:scaleType="centerInside" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rickshaw"
                            android:textColor="#0f172a"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Car Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardCar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#CBD5E1"
                    app:cardBackgroundColor="#DBEAFE"> <!-- Pastel Blue -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="8dp">
                        <ImageView
                            android:layout_width="60dp"
                            android:layout_height="50dp"
                            android:src="@drawable/car"
                            android:scaleType="centerInside" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Car"
                            android:textColor="#0f172a"
                            android:textSize="13sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Passenger Selection Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Number of Passengers"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_title_small"
                    android:fontFamily="sans-serif-medium" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <ImageView
                            android:id="@+id/btnMinusPassenger"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="8dp"
                            android:src="@drawable/ic_delete"
                            app:tint="?attr/colorOnSurfaceVariant"
                            android:background="?attr/selectableItemBackgroundBorderless" />

                        <TextView
                            android:id="@+id/tvPassengerCount"
                            android:layout_width="32dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="15sp"
                            android:fontFamily="sans-serif-bold" />

                        <ImageView
                            android:id="@+id/btnPlusPassenger"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="8dp"
                            android:src="@drawable/ic_add"
                            app:tint="?attr/colorPrimary"
                            android:background="?attr/selectableItemBackgroundBorderless" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="@dimen/spacing_md"
                android:background="?attr/colorOutlineVariant" />

            <!-- Offer Fare Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/offer_your_fare"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvRecommendedFare"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_body_small" />

            <!-- M3 Fare Stepper -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnMinusContainer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="@dimen/shape_full"
                    app:cardElevation="@dimen/elevation_none"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">

                    <ImageView
                        android:id="@+id/btnMinus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_delete"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/decrease" />
                </com.google.android.material.card.MaterialCardView>

                <!-- Fare Display -->
                <EditText
                    android:id="@+id/etFare"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="@dimen/spacing_md"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:inputType="number"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="@dimen/text_headline_small"
                    android:fontFamily="sans-serif-bold"
                    android:importantForAutofill="no"
                    tools:ignore="LabelFor" />

                <!-- Plus icon button -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnPlusContainer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:cardCornerRadius="@dimen/shape_full"
                    app:cardElevation="@dimen/elevation_none"
                    app:strokeColor="?attr/colorOutlineVariant"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="?attr/colorPrimaryContainer">

                    <ImageView
                        android:id="@+id/btnPlus"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="12dp"
                        android:src="@drawable/ic_add"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Increase" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Comment Input -->
            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:hint="Add comment for driver...">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:importantForAutofill="no" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Find Driver Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFindDriver"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/find_driver"
                style="@style/Widget.CoRide.Button.Primary" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
