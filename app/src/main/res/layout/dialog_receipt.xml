<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="@dimen/drag_handle_width"
        android:layout_height="@dimen/drag_handle_height"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@drawable/indicator_m3_drag" />

    <!-- Modern Receipt Ticket -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#e2e8f0"
        app:cardBackgroundColor="#19FF5722">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Elegant Success Header (Branded) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF2F2">
                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_check"
                    app:tint="#EF4444" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:text="Ride Receipt"
                android:textColor="#0f172a"
                android:textSize="20sp"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/tvReceiptDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Today • 12:45 PM"
                android:textColor="#64748b"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium" />

            <!-- Trip Route Visualization -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="16dp"
                    android:layout_height="60dp"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/bg_circle_primary" />
                    <View
                        android:layout_width="2dp"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="#e2e8f0" />
                    <ImageView
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:src="@drawable/location"
                        app:tint="#ef4444" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:text="University Main Gate"
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:lines="1"
                        android:ellipsize="end" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:text="Student Hostel Annex"
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:lines="1"
                        android:ellipsize="end" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dashed Divider simulated -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="24dp"
                android:background="#e2e8f0" />

            <!-- Fare Breakdown Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Fare Breakdown"
                android:textColor="#64748b"
                android:textSize="12sp"
                android:fontFamily="sans-serif-bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />

            <!-- Breakdown Rows -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical">

                <!-- Base Fare -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Trip Charge"
                        android:textColor="#475569"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif" />
                    <TextView
                        android:id="@+id/tvBaseFare"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="₨ 1,200"
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </RelativeLayout>

                <!-- Service Fee -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Platform Fee"
                        android:textColor="#475569"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif" />
                    <TextView
                        android:id="@+id/tvServiceFee"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="₨ 50"
                        android:textColor="#0f172a"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </RelativeLayout>

                <!-- Discount -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eco Reward"
                        android:textColor="#10b981"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                    <TextView
                        android:id="@+id/tvDiscount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="- ₨ 20"
                        android:textColor="#10b981"
                        android:textSize="14sp"
                        android:fontFamily="sans-serif-medium" />
                </RelativeLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:layout_marginTop="24dp"
                android:background="#f1f5f9" />

            <!-- Total Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Paid"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvTotalPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₨ 1,230"
                    android:textColor="#ef4444"
                    android:textSize="28sp"
                    android:fontFamily="sans-serif-black" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="end"
                android:text="Paid securely with CoRide Wallet"
                android:textColor="#94a3b8"
                android:textSize="11sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>

