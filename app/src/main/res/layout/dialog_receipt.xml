<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xl"
    android:background="@drawable/bg_bottom_sheet">

    <View
        android:layout_width="@dimen/drag_handle_width"
        android:layout_height="@dimen/drag_handle_height"
        android:layout_gravity="center"
        android:layout_marginBottom="@dimen/spacing_lg"
        android:background="@drawable/indicator_m3_drag" />

    <!-- Receipt Card Content -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/shape_medium"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/outline_variant"
        app:cardBackgroundColor="@color/surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Success Header -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/bg_circle_primary_subtle"
                app:tint="@color/primary" />
            
            <ImageView
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:layout_marginTop="-56dp"
                android:src="@drawable/payment" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center"
                android:text="@string/payment_successful"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-bold" />

            <TextView
                android:id="@+id/tvReceiptDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="May 24, 2024 • 2:30 PM"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body_small" />

            <!-- Fare Breakdown Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:text="@string/fare_breakdown"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_label_large"
                android:fontFamily="sans-serif-medium" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:background="@color/outline_variant" />

            <!-- Base Fare -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/base_fare"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="@dimen/text_body_medium" />
                <TextView
                    android:id="@+id/tvBaseFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₨ 1,200"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_body_medium" />
            </RelativeLayout>

            <!-- Service Fee -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/service_fee"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="@dimen/text_body_medium" />
                <TextView
                    android:id="@+id/tvServiceFee"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₨ 50"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_body_medium" />
            </RelativeLayout>

            <!-- Discount -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/discount"
                    android:textColor="@color/success"
                    android:textSize="@dimen/text_body_medium" />
                <TextView
                    android:id="@+id/tvDiscount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="- ₨ 0"
                    android:textColor="@color/success"
                    android:textSize="@dimen/text_body_medium" />
            </RelativeLayout>

            <!-- Divider (Dashed appearance hint) -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="@color/outline" />

            <!-- Total Paid Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_paid"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_title_medium"
                    android:fontFamily="sans-serif-bold" />
                <TextView
                    android:id="@+id/tvTotalPaid"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="₨ 1,250"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_headline_small"
                    android:fontFamily="sans-serif-bold" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="end"
                android:text="@string/paid_with_cash"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_body_small" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseReceipt"
        style="@style/Widget.InDrive.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:layout_marginTop="@dimen/spacing_xl"
        android:text="@string/done" />

</LinearLayout>
