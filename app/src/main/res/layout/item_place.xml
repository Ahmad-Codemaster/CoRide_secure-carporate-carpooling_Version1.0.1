<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="@dimen/spacing_md"
    android:paddingVertical="@dimen/spacing_md"
    android:background="?attr/selectableItemBackground">

    <!-- Location icon container — small circle -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:cardCornerRadius="@dimen/shape_full"
        app:cardElevation="@dimen/elevation_none"
        app:cardBackgroundColor="@color/surface_container">

        <ImageView
            android:id="@+id/ivPlaceIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:src="@drawable/ic_history"
            android:tint="@color/on_surface_variant"
            android:contentDescription="Place" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Place Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/spacing_md"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvPlaceName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/on_surface"
            android:textSize="@dimen/text_body_medium"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tvPlaceAddress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/on_surface_variant"
            android:textSize="@dimen/text_body_small"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

</LinearLayout>

