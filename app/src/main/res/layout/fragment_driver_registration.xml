<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/registrationHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_car"
            app:tint="@color/on_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Driver Enrollment"
            android:textColor="@color/on_primary"
            android:textSize="28sp"
            android:fontFamily="sans-serif-bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Turn your commute into earnings"
            android:textColor="#B0E0FF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Form Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:backgroundTint="@color/surface"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/registrationHeader"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.InDrive.TopImage">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Information"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="16dp" />

                <!-- Vehicle Make -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilVehicleMake"
                    style="@style/Widget.InDrive.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Vehicle Make (e.g. Toyota)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleMake"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Vehicle Model -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilVehicleModel"
                    style="@style/Widget.InDrive.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="Vehicle Model (e.g. Corolla)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etVehicleModel"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Plate Number -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPlateNumber"
                    style="@style/Widget.InDrive.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:hint="License Plate (e.g. LEA-1234)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPlateNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters" />
                </com.google.android.material.textfield.TextInputLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/outline_variant"
                    android:layout_marginVertical="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Legal Documents"
                    android:textColor="@color/primary"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold"
                    android:layout_marginBottom="16dp" />

                <!-- License Number -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilLicenseNumber"
                    style="@style/Widget.InDrive.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:hint="Driving License Number">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etLicenseNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Disclaimer -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="By clicking 'Finish', you agree to our Driver Terms &amp; Conditions and consent to a background identity check via your institution."
                    android:textColor="@color/on_surface_variant"
                    android:textSize="12sp"
                    android:layout_marginBottom="24dp" />

                <!-- Submit Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitDriver"
                    style="@style/Widget.InDrive.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Complete Registry" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancelDriver"
                    style="@style/Widget.InDrive.Button.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="12dp"
                    android:text="Maybe Later" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
