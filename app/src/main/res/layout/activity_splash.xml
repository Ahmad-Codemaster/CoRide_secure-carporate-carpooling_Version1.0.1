<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary"
    android:gravity="center"
    android:orientation="vertical">

    <!-- Hero Container — expressive large circle -->
    <LinearLayout
        android:id="@+id/heroContainer"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:background="@drawable/bg_m3_logo_circle"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0"
        android:scaleX="0.5"
        android:scaleY="0.5">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/bogo"

            android:contentDescription="CoRide Logo"
            />
    </LinearLayout>

    <!-- App Name — Display Medium — spring slides up -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_lg"
        android:text="CoRide"
        android:textColor="@color/on_primary"
        android:textSize="@dimen/text_display_small"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="0.02"
        android:alpha="0"
        android:translationY="40dp" />

    <!-- Tagline — Title Small -->
    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="Verified rides for students \u0026 employees"
        android:textColor="#FFFFFF"
        android:textSize="@dimen/text_title_small"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.04"
        android:alpha="0"
        android:translationY="30dp" />

    <!-- Animated Dots Row — spring pulse -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_xxl"
        android:orientation="horizontal"
        android:gravity="center"
        android:alpha="0">

        <View
            android:id="@+id/dot1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_splash_dot"
            android:alpha="1.0"
            android:scaleX="1.0"
            android:scaleY="1.0" />

        <View
            android:id="@+id/dot2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_splash_dot"
            android:alpha="0.4"
            android:scaleX="0.7"
            android:scaleY="0.7" />

        <View
            android:id="@+id/dot3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginHorizontal="5dp"
            android:background="@drawable/bg_splash_dot"
            android:alpha="0.4"
            android:scaleX="0.7"
            android:scaleY="0.7" />
    </LinearLayout>

</LinearLayout>

