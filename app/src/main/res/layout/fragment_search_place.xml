<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#A7D3D3D3"
    android:orientation="vertical">

    <!-- Floating Glassy Search Bar Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:background="#00000000"
        android:translationZ="10dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearchContainer"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#E6FFFFFF"
            app:strokeWidth="1.5dp"
            app:strokeColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="#0f172a"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Search destination..."
                    android:imeOptions="actionSearch"
                    android:inputType="text"
                    android:paddingHorizontal="8dp"
                    android:textColor="#0f172a"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintEnd_toEndOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Category Chips (Professional Search Feature) -->
        <HorizontalScrollView
            android:id="@+id/chipScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/cardSearchContainer">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/categoryChips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipRestaurant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Restaurants"
                    app:chipIcon="@drawable/ic_star"
                    style="@style/Widget.Material3.Chip.Suggestion" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipATM"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ATM"
                    app:chipIcon="@drawable/ic_card"
                    style="@style/Widget.Material3.Chip.Suggestion" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPetrol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Petrol"
                    app:chipIcon="@drawable/ic_car"
                    style="@style/Widget.Material3.Chip.Suggestion" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHospital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hospital"
                    app:chipIcon="@drawable/ic_info"
                    style="@style/Widget.Material3.Chip.Suggestion" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="160dp">

            <!-- Pick on Map Action -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnPickOnMap"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeColor="#e2e8f0"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_map"
                        app:tint="#6366f1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Set destination on map"
                        android:textColor="#6366f1"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-bold" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchResults"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="40dp" />
        </LinearLayout>

        <!-- No Results Hint -->
        <TextView
            android:id="@+id/tvNoResults"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No search results. Try searching for a specific location or category."
            android:textColor="#64748b"
            android:visibility="gone"
            android:paddingHorizontal="40dp"
            android:gravity="center" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</LinearLayout>

