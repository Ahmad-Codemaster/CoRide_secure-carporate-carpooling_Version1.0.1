<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="#A7E6E6E6"
    android:layout_height="match_parent">

    <!-- Morphing Floating Header -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerPill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="0dp"
        android:layout_marginTop="0dp"
        app:cardBackgroundColor="#00FFFFFF"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        android:translationZ="10dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/homeHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="72dp"
            android:paddingTop="12dp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp">

            <!-- User Avatar (Shrinkable) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/ivUserAvatarCard"
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#0f172a"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <ImageView
                    android:id="@+id/ivUserAvatar"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:src="@drawable/profile2"
                    app:tint="@color/accent_light" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutUserText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="18dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivUserAvatarCard"
                app:layout_constraintEnd_toStartOf="@id/btnToggleMap">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning,"
                    android:textColor="#64748b"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textStyle="bold"
                    android:textColor="#0f172a"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold" />
            </LinearLayout>

            <!-- Map Toggle Button (Shrinkable) -->
            <Button
                android:id="@+id/btnToggleMap"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:text="Map"
                app:icon="@drawable/ic_map"
                app:iconTint="#FFFFFF"
                android:textColor="#FFFFFF"
                android:backgroundTint="#0f172a"
                app:cornerRadius="25dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeContentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:clipToPadding="false"
        android:paddingTop="90dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="120dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp">

                <!-- Total Spending Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/spendingCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    android:layout_marginTop="30dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/accent_light"
                    app:strokeColor="#e2e8f0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <!-- Bolt / Spending Icon -->
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                app:cardCornerRadius="20dp"
                                app:cardBackgroundColor="#0f172a"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_bolt"
                                    app:tint="#FFFFFF" />
                            </com.google.android.material.card.MaterialCardView>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="16dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Total Spending"
                                    android:textColor="#64748b"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />

                                <TextView
                                    android:id="@+id/tvTotalSpending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="$0.00"
                                    android:textColor="#0f172a"
                                    android:textSize="26sp"
                                    android:fontFamily="sans-serif-bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Subtle Trend Badge -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            app:cardBackgroundColor="#ECFDF5"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="0dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <!-- Using chevron up or trend icon, I'll use star or just text -->
                                <ImageView
                                    android:layout_width="14dp"
                                    android:layout_height="14dp"
                                    android:src="@drawable/ic_chevron_right"
                                    android:rotation="-90"
                                    app:tint="#059669" />
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="4dp"
                                    android:text=" taken rides"
                                    android:textColor="#059669"
                                    android:textSize="12sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Search / Where To -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/searchCard"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:layout_marginTop="24dp"
                    app:cardBackgroundColor="@color/accent_light"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#e2e8f0"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:padding="6dp"
                            android:src="@drawable/location"
                            app:tint="#3B82F6" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-bold"
                                android:text="Where to today?"
                                android:textColor="#0f172a"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/tvHomeMicroWidget"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Start your new journey here"
                                android:textColor="#64748b"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Quick Actions Grid -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Quick Actions"
                    android:textColor="#0f172a"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-bold" />

                <LinearLayout
                    android:id="@+id/quickActionsGrid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:padding="5dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <!-- Search Ride -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionRideNow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="#e2e8f0"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardCornerRadius="24dp"
                                app:cardBackgroundColor="#F1F5F9"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_search"
                                    app:tint="#64748B" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Search Ride"
                                android:textColor="#0f172a"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Book Now -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionBookNow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="#e2e8f0"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardCornerRadius="24dp"
                                app:cardBackgroundColor="#EFF6FF"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/location"
                                    app:tint="#3B82F6" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Book Now"
                                android:textColor="#0f172a"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Schedule -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/actionSchedule"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:strokeColor="#e2e8f0"
                        app:strokeWidth="1dp"
                        android:clickable="true"
                        android:focusable="true">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="110dp"
                            android:gravity="center"
                            android:orientation="vertical">
                            <com.google.android.material.card.MaterialCardView
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                app:cardCornerRadius="24dp"
                                app:cardBackgroundColor="#ECFDF5"
                                app:cardElevation="0dp">
                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_schedule"
                                    app:tint="#10B981" />
                            </com.google.android.material.card.MaterialCardView>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="Schedule"
                                android:textColor="#0f172a"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Recent Rides -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent Rides"
                        android:textColor="#0f172a"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-bold" />
                    <TextView
                        android:id="@+id/tvViewAllHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All"
                        android:textColor="#3B82F6"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:padding="8dp" />
                </LinearLayout>

                <!-- Recent Rides Container (Populated by Kotlin) -->
                <LinearLayout
                    android:id="@+id/layoutRecentRides"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="12dp">
                    
                    <!-- Dynamic content falls here -->
                    <TextView
                        android:id="@+id/tvNoRides"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:paddingVertical="24dp"
                        android:text="no rides have been taken"
                        android:textColor="#94a3b8"
                        android:fontFamily="sans-serif"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Saved Addresses Section (Add Location) -->
                <LinearLayout
                    android:id="@+id/savedAddressesSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="32dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif-bold"
                                android:text="Saved Locations"
                                android:textColor="#0f172a"
                                android:textSize="18sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:paddingBottom="5dp"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnAddAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="#e2e8f0"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="10dp">
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#DCFCE7"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">
                                    <ImageView
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_add"
                                        app:tint="#22C55E" />
                                </com.google.android.material.card.MaterialCardView>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Add"
                                    android:textColor="#0f172a"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="#e2e8f0"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="10dp">
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#EFF6FF"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">
                                    <ImageView
                                        android:layout_width="12dp"
                                        android:layout_height="12dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/location"
                                        app:tint="#3B82F6" />
                                </com.google.android.material.card.MaterialCardView>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Home"
                                    android:textColor="#0f172a"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btnWork"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:cardBackgroundColor="#FFFFFF"
                            app:cardCornerRadius="20dp"
                            app:strokeColor="#e2e8f0"
                            app:strokeWidth="1dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="16dp"
                                android:paddingVertical="10dp">
                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    app:cardCornerRadius="12dp"
                                    app:cardBackgroundColor="#FFEDD5"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp">
                                    <ImageView
                                        android:layout_width="14dp"
                                        android:layout_height="14dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_work"
                                        app:tint="#F97316" />
                                </com.google.android.material.card.MaterialCardView>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="Work"
                                    android:textColor="#0f172a"
                                    android:textSize="13sp"
                                    android:fontFamily="sans-serif-medium" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Weather FAB keeping it here since UI bindings need it -->
    <LinearLayout
        android:id="@+id/weatherActionCornerHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="20dp"
        android:gravity="end"
        android:layout_gravity="bottom|end">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWeatherPopupHome"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="?attr/colorSurface">
            <LinearLayout
                android:id="@+id/layoutWeatherDaysHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp">
            <ImageView
                android:id="@+id/ivWeatherGlowHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_weather_glow_aurora" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/cloud"
                app:backgroundTint="?attr/colorSurface"
                app:elevation="0dp"
                app:fabSize="mini"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.CoRide.Full"
                app:tint="?attr/colorPrimary"
                tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />
        </FrameLayout>
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
