<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 1. Background Image Layer (Absolute Bottom) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivHomeBackground"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:scaleType="centerCrop"
        android:src="@drawable/banner"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.InDrive.TopImage"
        android:contentDescription="Background" />

    <!-- 2. Header Content Layer (Profile info, Map toggle) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="48dp"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- User Avatar -->

        <!-- Greeting -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivUserAvatar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:padding="8dp"
            android:src="@drawable/profile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            app:layout_constraintTop_toTopOf="@id/ivUserAvatar"
            app:layout_constraintBottom_toBottomOf="@id/ivUserAvatar"
            app:layout_constraintStart_toEndOf="@id/ivUserAvatar"
            app:layout_constraintEnd_toStartOf="@id/btnToggleMap">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Good morning,"
                android:textStyle="bold"
                android:textColor="@color/background_card"
                android:textSize="@dimen/text_title_medium"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <!-- Map Toggle Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnToggleMap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Map"
            app:icon="@drawable/ic_map"
            style="@style/Widget.Material3.Button.TonalButton"
            app:backgroundTint="@color/surface_container_low"
            app:iconTint="@color/primary"
            android:textColor="@color/primary"
            app:layout_constraintTop_toTopOf="@id/ivUserAvatar"
            app:layout_constraintBottom_toBottomOf="@id/ivUserAvatar"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 3. Main Rolling Content Area -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeContentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="160dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingHorizontal="@dimen/spacing_lg"
            android:paddingBottom="120dp">

            <!-- Promo Banner -->

            <!-- Search Card Overlay -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                app:cardCornerRadius="@dimen/shape_full"
                app:cardElevation="@dimen/elevation_lg"
                app:cardBackgroundColor="@color/surface_container_lowest"
                android:layout_marginTop="@dimen/spacing_lg"
                android:alpha="0"
                android:translationY="30dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_map"
                        app:tint="@color/primary" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/where_to"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_body_large"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:id="@+id/tvHomeMicroWidget"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Traffic is light • 12 mins to Arfa Tower"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Quick Actions Grid -->
            <LinearLayout
                android:id="@+id/quickActionsGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="horizontal"
                android:gravity="center"
                android:alpha="0"
                android:translationY="35dp">

                <!-- Ride Now -->
                <LinearLayout
                    android:id="@+id/actionRideNow"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/primary_container">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_bolt"
                            app:tint="@color/primary" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Ride Now"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- Schedule -->
                <LinearLayout
                    android:id="@+id/actionSchedule"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_container_high">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_schedule"
                            app:tint="@color/on_surface_variant" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Schedule"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <!-- SOS/Security -->
                <LinearLayout
                    android:id="@+id/actionSecurity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_container_high">
                        <ImageView
                            android:layout_width="26dp"
                            android:layout_height="26dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_shield_check"
                            app:tint="@color/on_surface_variant" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Security"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

            </LinearLayout>

            <!-- Safety Trust Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/safetyBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardCornerRadius="@dimen/shape_large"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/secondary_container"
                android:alpha="0"
                android:translationY="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_shield_check"
                        app:tint="@color/on_secondary_container" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CoRide Trust Network"
                            android:textColor="@color/on_secondary_container"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:id="@+id/tvSafetyStats"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="98% Drivers Verified Today"
                            android:textColor="@color/on_secondary_container"
                            android:textSize="12sp"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnLearnMoreSafety"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Learn More"
                        android:textColor="@color/on_secondary_container"
                        android:textSize="12sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Popular Destinations Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/destinationsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                app:cardCornerRadius="@dimen/shape_large"
                app:cardElevation="@dimen/elevation_none"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="1dp"
                app:cardBackgroundColor="@color/surface"
                android:alpha="0"
                android:translationY="40dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Popular destinations"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_title_medium"
                            android:fontFamily="sans-serif-bold" />

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/on_surface_variant" />
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvRecentPlaces"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@android:layout/simple_list_item_2" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Saved Addresses Section -->
            <LinearLayout
                android:id="@+id/savedAddressesSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:orientation="vertical"
                android:alpha="0"
                android:translationY="50dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Saved addresses"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_title_medium"
                            android:fontFamily="sans-serif-bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Never Forget an Address Again!"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_label_large" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddAddress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Add"
                        app:icon="@drawable/ic_add"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:textColor="@color/primary"
                        app:iconTint="@color/primary"
                        app:strokeColor="@color/primary"
                        android:paddingHorizontal="@dimen/spacing_md" />
                </LinearLayout>

                <!-- Saved Chips (Home, Work, etc.) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnHome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        app:cardCornerRadius="@dimen/shape_full"
                        app:cardElevation="@dimen/elevation_none"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline_variant">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="@dimen/spacing_sm"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_location_pin"
                                app:tint="@color/primary"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="Home"
                                android:textColor="@color/on_surface"
                                android:textSize="@dimen/text_label_large"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnWork"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="@dimen/shape_full"
                        app:cardElevation="@dimen/elevation_none"
                        app:cardBackgroundColor="@color/surface_container_low"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/outline_variant">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="@dimen/spacing_md"
                            android:paddingVertical="@dimen/spacing_sm"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_work"
                                app:tint="@color/primary"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/spacing_xs"
                                android:text="Work"
                                android:textColor="@color/on_surface"
                                android:textSize="@dimen/text_label_large"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 4. Weather Action Corner (Bottom Right Floating) -->
    <LinearLayout
        android:id="@+id/weatherActionCornerHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="100dp"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:gravity="end"
        android:layout_gravity="bottom|end">

        <!-- Weather Popup Card (Solid White, Above FAB) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvWeatherPopupHome"
            android:layout_width="160dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:visibility="gone"
            android:alpha="0"
            android:translationY="20dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="#FFFFFF"> <!-- Solid White -->

            <LinearLayout
                android:id="@+id/layoutWeatherDaysHome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="8dp" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Spiral Outline + FAB Container -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp">

            <!-- Animated Glowy Aurora Outline (Glow Effect) -->
            <ImageView
                android:id="@+id/ivWeatherGlowHome"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/bg_weather_glow_aurora" />

            <!-- Shadowless Home Weather FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabWeatherHome"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/cloud"
                app:tint="@color/primary"
                app:backgroundTint="@color/surface_container_lowest"
                app:fabSize="mini"
                app:elevation="0dp"
                app:pressedTranslationZ="0dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.InDrive.Full" />
        </FrameLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
