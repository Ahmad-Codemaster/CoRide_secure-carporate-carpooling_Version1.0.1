<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:padding="24dp">

    <!-- Warning Icon -->
    <ImageView
        android:id="@+id/ivSafetyIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:src="@drawable/ic_warning"
        app:tint="@color/warning" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvSafetyTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Are you okay?"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        android:textAlignment="center"
        android:fontFamily="sans-serif-bold" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvSafetyMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Your ride appears to have stopped moving. We want to make sure you are safe."
        android:textColor="@color/on_surface_variant"
        android:textSize="14sp"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp" />

    <!-- Timer -->
    <TextView
        android:id="@+id/tvSafetyTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:text="Auto-alerting in 30s"
        android:textColor="@color/error"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium" />

    <!-- I'm OK Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSafetyOk"
        style="@style/Widget.CoRide.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:text="✅ I'm OK"
        app:cornerRadius="28dp" />

    <!-- Help / SOS Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSafetyHelp"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:text="🆘 I Need Help"
        android:textColor="@color/on_error"
        android:backgroundTint="@color/error"
        app:cornerRadius="28dp" />

</LinearLayout>

