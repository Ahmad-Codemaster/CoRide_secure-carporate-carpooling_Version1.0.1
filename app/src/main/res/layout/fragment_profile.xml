<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_low">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="100dp">

        <!-- Profile Header — gradient primary banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rounded_card_red"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_xl"
            android:paddingBottom="@dimen/spacing_xl"
            android:paddingHorizontal="@dimen/spacing_lg">

            <!-- Avatar — ShapeableImageView full-round -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:src="@drawable/profile"
                android:padding="@dimen/spacing_lg"
                android:contentDescription="@string/profile_photo" />

            <!-- Name — Headline Small, white -->
            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textColor="@color/on_primary"
                android:textSize="@dimen/text_headline_small"
                android:fontFamily="sans-serif-medium" />

            <!-- Phone — Body Small, semi-white -->
            <TextView
                android:id="@+id/tvUserPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="#A0D8F0"
                android:textSize="@dimen/text_body_small" />

            <!-- CoRide: Verification Badge -->
            <TextView
                android:id="@+id/tvVerificationBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xs"
                android:textColor="@color/on_primary"
                android:textSize="@dimen/text_label_large"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone" />

            <!-- CoRide: Role + Organization -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A0D8F0"
                    android:textSize="@dimen/text_label_medium"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#A0D8F0"
                    android:textSize="@dimen/text_label_medium"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvOrganization"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#A0D8F0"
                    android:textSize="@dimen/text_label_medium"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- Stats Row -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:cardBackgroundColor="#20FFFFFF"
                app:cardCornerRadius="@dimen/shape_medium"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                <!-- Rides -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvTotalRides"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_headline_small"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/total_rides"
                        android:textColor="#A0D8F0"
                        android:textSize="@dimen/text_label_medium" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:background="#40FFFFFF" />

                <!-- Rating -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_headline_small"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Status"
                        android:textColor="#A0D8F0"
                        android:textSize="@dimen/text_label_medium" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center_vertical"
                    android:background="#40FFFFFF" />

                <!-- Member Since -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tvMemberSince"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/on_primary"
                        android:textSize="@dimen/text_body_small"
                        android:fontFamily="sans-serif-bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/member_since"
                        android:textColor="#A0D8F0"
                        android:textSize="@dimen/text_label_medium" />
                </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Unverified Warning Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bannerUnverified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/spacing_md"
            android:layout_marginTop="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/shape_medium"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFF3E0"
            app:strokeColor="#FFB74D"
            app:strokeWidth="1dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_md">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_warning"
                    android:contentDescription="Warning"
                    app:tint="#E65100" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="Your account is not verified. Tap Verification below to get full access."
                    android:textColor="#E65100"
                    android:textSize="@dimen/text_body_small" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Menu Section — M3 surface container white -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_md"
            app:cardCornerRadius="@dimen/shape_large"
            app:cardElevation="@dimen/elevation_none"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/surface_container_lowest">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Edit Profile -->
                <LinearLayout
                    android:id="@+id/btnEditProfile"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_edit"
                        android:contentDescription="Edit"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="@string/edit_profile"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- Verification -->
                <LinearLayout
                    android:id="@+id/btnVerification"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_info"
                        android:contentDescription="Verify"
                        app:tint="@color/primary" />

                    <TextView
                        android:id="@+id/tvVerificationLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Verification"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <TextView
                        android:id="@+id/tvVerificationStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:textSize="@dimen/text_label_medium"
                        android:fontFamily="sans-serif-medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- Security Center (Trusted Contacts) -->
                <LinearLayout
                    android:id="@+id/btnSecurityCenter"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_shield_check"
                        android:contentDescription="Security"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Security Center"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- Security Settings (Biometrics) -->
                <LinearLayout
                    android:id="@+id/btnSecuritySettings"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/biometric"
                        android:contentDescription="Biometrics"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="Security Settings"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_settings"
                        android:contentDescription="Settings"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="@string/settings"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- Help -->
                <LinearLayout
                    android:id="@+id/btnHelp"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_help"
                        android:contentDescription="Help"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="@string/help"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="56dp" android:background="@color/outline_variant" />

                <!-- About -->
                <LinearLayout
                    android:id="@+id/btnAbout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_info"
                        android:contentDescription="About"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_md"
                        android:text="@string/about"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_body_medium" />

                    <ImageView
                        android:layout_width="@dimen/icon_sm"
                        android:layout_height="@dimen/icon_sm"
                        android:src="@drawable/ic_chevron_right"
                        android:contentDescription="Arrow"
                        app:tint="@color/on_surface_variant" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Sign Out -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignOut"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginHorizontal="@dimen/spacing_lg"
            android:layout_marginBottom="@dimen/spacing_lg"
            android:text="@string/sign_out"
            android:textColor="@color/primary"
            style="@style/Widget.InDrive.Button.Secondary"
            app:strokeColor="@color/primary" />

    </LinearLayout>
</ScrollView>
