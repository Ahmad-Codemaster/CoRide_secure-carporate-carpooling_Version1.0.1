<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <!-- Top Branding Section -->
    <LinearLayout
        android:id="@+id/topSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="48dp"
        android:paddingHorizontal="@dimen/spacing_xl"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textColor="@color/on_primary"
            android:textSize="@dimen/text_headline_medium"
            android:fontFamily="sans-serif-bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Join the secure CoRide platform"
            android:textColor="#B0E0FF"
            android:textSize="@dimen/text_body_medium" />
    </LinearLayout>

    <!-- Bottom Card Section -->
    <LinearLayout
        android:id="@+id/bottomCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_bottom_sheet"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xl"
        app:layout_constraintTop_toBottomOf="@+id/topSection"
        app:layout_constraintBottom_toBottomOf="parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/spacing_xxl">

                <!-- Full Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="John Doe"
                        android:inputType="textPersonName"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />
                </LinearLayout>

                <!-- Email Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Email Address"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="student@domain.edu"
                        android:inputType="textEmailAddress"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />
                </LinearLayout>

                <!-- Phone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Phone Number"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="0312 3456789"
                        android:inputType="phone"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />
                </LinearLayout>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Password"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:hint="••••••••"
                        android:inputType="textPassword"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />

                    <ImageButton
                        android:id="@+id/ivPasswordToggle"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_visibility"
                        app:tint="@color/outline"
                        android:padding="12dp"
                        android:contentDescription="Show/Hide Password" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="@dimen/spacing_lg"
                    android:background="@color/outline_variant" />

                <!-- Required Institutional Fields Header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Community Identity (Required)"
                    android:textColor="@color/primary"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-bold" />

                <!-- Organization -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Organization / University"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etOrganization"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. LUMS, FAST NUCES"
                        android:inputType="text"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />
                </LinearLayout>

                <!-- Student ID -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="Registration Number"
                    android:textColor="@color/on_surface"
                    android:textSize="@dimen/text_label_large"
                    android:fontFamily="sans-serif-medium" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="@drawable/bg_input_default"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/spacing_md">

                    <EditText
                        android:id="@+id/etStudentId"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="e.g. 21L-1234"
                        android:inputType="text"
                        android:textColor="@color/on_surface"
                        android:textColorHint="@color/outline"
                        android:textSize="@dimen/text_body_large" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRegister"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/spacing_xl"
                    android:text="Create Account"
                    style="@style/Widget.InDrive.Button.Primary"
                    android:textSize="@dimen/text_label_large" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Already have an account? "
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body_medium" />

                    <TextView
                        android:id="@+id/tvLoginLink"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log in"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_body_medium"
                        android:fontFamily="sans-serif-bold"
                        android:background="?attr/selectableItemBackground" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
